# Canonical formatter: clang-format 21 (`make format`). Re-baselined 2026-06-29 to match
# the established house style — namespace contents at column 0, access labels at column 0,
# template declarations on their own line, short inline accessors kept on one line.
BasedOnStyle: Google
CommentPragmas: '(@copydoc)'

# Pointers
DerivePointerAlignment: false
PointerAlignment: Left

# Indents
AccessModifierOffset: -4
IndentWidth: 4
TabWidth: 4
UseTab: "Never"
NamespaceIndentation: None
IndentGotoLabels: true

# Alignments
AlignConsecutiveAssignments:
  # The column at which the = starts is constant among a block of definitions.
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true
  AlignCompound: true
  PadOperators: false
AlignConsecutiveBitFields:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true
AlignConsecutiveDeclarations:
  # The column at which the name starts is constant among a block of declarations / definitions.
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true
AlignConsecutiveMacros:
  Enabled: true
  AcrossEmptyLines: false
  AcrossComments: true

# Line breaks
AlwaysBreakTemplateDeclarations: Yes
AllowShortFunctionsOnASingleLine: Inline
AllowShortEnumsOnASingleLine: false
KeepEmptyLinesAtTheStartOfBlocks: true
BreakBeforeBraces: Custom
BraceWrapping:
  AfterClass: false
  AfterControlStatement: false
  AfterEnum: false
  AfterFunction: false
  AfterNamespace: false
  AfterStruct: false
  AfterUnion: false
  BeforeCatch: false
  BeforeElse: false
ColumnLimit: 120

# Includes
IncludeBlocks: Merge
